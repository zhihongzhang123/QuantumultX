# X(Twitter) 自动翻译中文
#!name=X Auto Translate
#!desc=自动将 X/Twitter 网页版英文内容翻译为中文
#!author=minimac
#!tag=翻译, X
#!system=iOS, iPadOS
#!date=2026-05-02

# === X/Twitter HTML Shell 拦截 ===
^https://x\.com/$ url script-response-body https://raw.githubusercontent.com/zhihongzhang123/QuantumultX/main/Scripts/XTranslate.js
^https://x\.com/home url script-response-body https://raw.githubusercontent.com/zhihongzhang123/QuantumultX/main/Scripts/XTranslate.js
^https://twitter\.com/$ url script-response-body https://raw.githubusercontent.com/zhihongzhang123/QuantumultX/main/Scripts/XTranslate.js

# === X GraphQL API 拦截 - 注入翻译标记 ===
^https://x\.com/i/api/graphql/ url script-response-body https://raw.githubusercontent.com/zhihongzhang123/QuantumultX/main/Scripts/XTranslate.js
^https://twitter\.com/i/api/graphql/ url script-response-body https://raw.githubusercontent.com/zhihongzhang123/QuantumultX/main/Scripts/XTranslate.js

hostname = x.com, twitter.com
